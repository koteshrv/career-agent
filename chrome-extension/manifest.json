{
  "manifest_version": 3,
  "name": "Job Tracker Pro",
  "version": "1.0",
  "description": "Instantly save jobs from any website to your Job Tracker Pro Kanban board.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*"
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
